<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block all cleartext (HTTP) traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Pin certificates for Supabase and kwen.in -->
    <domain-config>
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">supabase.in</domain>
        <domain includeSubdomains="true">kwen.in</domain>
        <pin-set expiration="2027-01-01">
            <!-- Let's Encrypt Root CA (ISRG Root X1) -->
            <pin digest="SHA-256">C/BDigBHc9LV6bZegLg7u7GJe8cR7H1drkIgMFMVnwk=</pin>
            <!-- Let's Encrypt Root CA (ISRG Root X2) -->
            <pin digest="SHA-256">diGVwiVYbubAI3RW4hB9xU8e/CH2GGvrTMwlPhKpoBc=</pin>
            <!-- Backup: DigiCert Global Root CA -->
            <pin digest="SHA-256">W9oeJRBz0pJZ7GjPrDm0QI9VEFsYyemHxDeHFm0eMEs="</pin>
        </pin-set>
    </domain-config>
</network-security-config>
